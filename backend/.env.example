# Backend TCC ITPLN — salin ke .env dan isi nilainya (JANGAN commit .env)
APP_ENV=production
APP_PORT=8080

# Postgres (dari Coolify Postgres atau Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Rahasia untuk sign/verify JWT sesi (string acak panjang, min 32 char)
SUPABASE_JWT_SECRET=ganti-dengan-string-acak-panjang

# Origin frontend yang diizinkan (CORS) — sesuaikan dengan domain frontend
CORS_ALLOWED_ORIGINS=https://tcc.web.id

# Midtrans (pakai Sandbox saat demo)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# Bynara AI chatbot
BYNARA_BASE_URL=https://router.bynara.id/v1
BYNARA_API_KEY=
BYNARA_MODEL=mistral-medium-3-5
